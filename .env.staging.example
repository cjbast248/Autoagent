# =============================================================================
# KALLINA.INFO - STAGING ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.staging and fill in the values
# cp .env.staging.example .env.staging
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE - USE A SEPARATE PROJECT FOR STAGING!
# Create a new project at https://supabase.com/dashboard
# -----------------------------------------------------------------------------
SUPABASE_URL=https://YOUR_STAGING_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_staging_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_staging_service_role_key

# -----------------------------------------------------------------------------
# AI & Voice Services (can use same as production or separate)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key
GROQ_API_KEY=your_groq_api_key
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# -----------------------------------------------------------------------------
# Payment Processing (USE TEST MODE KEYS!)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_your_stripe_test_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_test_key

# -----------------------------------------------------------------------------
# Email Services
# -----------------------------------------------------------------------------
RESEND_API_KEY=your_resend_api_key

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
NODE_ENV=staging
VITE_APP_URL=https://dev.kallina.info

# ElevenLabs Configuration
VITE_ELEVENLABS_BASE_URL=https://api.elevenlabs.io/v1
VITE_DEFAULT_MODEL_ID=eleven_flash_v2_5
VITE_AGENT_PHONE_NUMBER_ID=your_agent_phone_number_id

# -----------------------------------------------------------------------------
# Worker Configuration
# -----------------------------------------------------------------------------
WORKER_API_SECRET=kallina-staging-secret-change-me

# -----------------------------------------------------------------------------
# AmoCRM (can use same as production - it's per-user OAuth)
# -----------------------------------------------------------------------------
AMOCRM_CLIENT_ID=your_amocrm_client_id
AMOCRM_CLIENT_SECRET=your_amocrm_client_secret

# -----------------------------------------------------------------------------
# Asterisk Config API (for automatic PJSIP configuration)
# -----------------------------------------------------------------------------
ASTERISK_API_URL=http://193.53.40.79:3080
ASTERISK_API_KEY=your_asterisk_api_key_here
